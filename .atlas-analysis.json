  "keyFeatures": [
    "Real-time connection search across trains, buses, cable cars, and trams",
    "Interactive Leaflet map with GPS tracking and live departures",
    "Departure board with delay indicators and platform info",
    "Commuter mode for one-tap access to saved frequent routes",
    "Live service alerts and disruption reports from the transit network",
    "Route sharing via short links",
    "Multi-language support: German, Italian, English, and Ladin",
    "Light/dark/system-auto theme switching",
    "Cloud sync via Supabase with offline localStorage fallback"
  ],
  "publicApiSurface": [
    "searchStopsEfa(query: string): Promise<EfaStop[]>",
    "getRecentStops(): RecentStop[]",
    "getRecentConnections(): RecentConnection[]",
    "getLikedRoutes(): LikedRoute[]",
    "getCommuterRoutes(): CommuterRoute[]",
    "getActiveRoutes(): ActiveRoute[]",
    "getDepartureStations(): DepartureStation[]",
    "getQuickAccessItems(): QuickAccessItem[]",
    "syncAllToSupabase(): Promise<void>",
    "syncAllFromSupabase(): Promise<void>",
    "router (React Router browser router with all app routes)"
  ]
}
